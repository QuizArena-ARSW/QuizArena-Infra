# Copia este archivo a ".env" (mismo directorio) y completa tus datos reales.
# ".env" está en .gitignore: nunca se sube al repo.
#
# Gmail: genera una "contraseña de aplicación" en
# https://myaccount.google.com/apppasswords (requiere verificación en 2 pasos
# activada en la cuenta). NO uses tu contraseña normal de Gmail.

MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=contraseña-de-aplicacion-de-16-caracteres
MAIL_FROM=tu-correo@gmail.com

# Google Gemini (bono de IA): API key gratis, sin tarjeta, en
# https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=tu-api-key-de-gemini
