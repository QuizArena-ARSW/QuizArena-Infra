{
  "title": "QuizArena · Operación y KPIs",
  "uid": "quizarena",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "Atributos de calidad (evidencia)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latencia de procesamiento de respuesta (p50 / p95 / p99)",
      "description": "Respalda el escenario de RENDIMIENTO: el servidor debe procesar una respuesta muy por debajo del presupuesto de 200 ms.",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "quizarena_respuesta_latencia_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "quizarena_respuesta_latencia_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "quizarena_respuesta_latencia_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Jugadores conectados",
      "description": "Respalda el escenario de ESCALABILIDAD. Al escalar, la suma cubre todas las instancias.",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 40 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(quizarena_jugadores_conectados)",
          "legendFormat": "conectados",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Salas activas",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }
      },
      "targets": [
        {
          "expr": "max(quizarena_salas_activas)",
          "legendFormat": "salas",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jugadores conectados por instancia",
      "description": "Evidencia del ESCALADO HORIZONTAL: muestra cómo la carga se reparte entre instancias del Servicio de Juego.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "expr": "quizarena_jugadores_conectados",
          "legendFormat": "{{instancia}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Respuestas procesadas por segundo",
      "description": "Carga real que soporta el sistema (throughput).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(quizarena_respuestas_total_total[1m]))",
          "legendFormat": "respuestas/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "KPIs de negocio",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "stat",
      "title": "Partidas iniciadas",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [
        { "expr": "sum(quizarena_partidas_iniciadas_total)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Partidas completadas",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 18 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [
        { "expr": "sum(quizarena_partidas_finalizadas_total)", "refId": "A" }
      ]
    },
    {
      "type": "gauge",
      "title": "Tasa de acierto",
      "description": "KPI pedagógico: qué proporción de respuestas son correctas. Una tasa muy baja señala temas que el grupo no domina.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(quizarena_respuestas_correctas_total) / clamp_min(sum(quizarena_respuestas_total_total), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Respuestas totales",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 18 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [
        { "expr": "sum(quizarena_respuestas_total_total)", "refId": "A" }
      ]
    }
  ]
}
